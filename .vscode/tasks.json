{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Build with make",
            "command": "make",
            "args": [
                "all"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build the project using the repository Makefile."
        },
        {
            "type": "shell",
            "label": "Clean with make",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Clean build outputs using the repository Makefile."
        }
    ]
}